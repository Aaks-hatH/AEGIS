# Production environment template (set these as env vars in the Render dashboard,
# not in a committed file). FRONTEND_URL / CORS_ORIGIN default to Render's
# RENDER_EXTERNAL_URL automatically, so you usually only need MONGODB_URI.
NODE_ENV=production
JWT_SECRET=set_a_long_random_secret
JWT_EXPIRES_IN=2h
COOKIE_SECURE=true
VITE_API_URL=/api
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/aegis?retryWrites=true&w=majority
# ANTHROPIC_API_KEY=optional
